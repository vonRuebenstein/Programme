# --- CONNECTION MANAGER (Abo-Modell) ---
class ConnectionManager:
    def __init__(self):
        self.active_connections: dict[WebSocket, set] = {}

    async def connect(self, websocket: WebSocket):
        await websocket.accept()
        self.active_connections[websocket] = set()
        logger.info(f"WS-CLIENT  | Verbunden. Gesamt: {len(self.active_connections)}")

    def disconnect(self, websocket: WebSocket):
        if websocket in self.active_connections:
            del self.active_connections[websocket]
            logger.info(f"WS-CLIENT  | Getrennt. Rest: {len(self.active_connections)}")

    async def update_subscription(self, websocket: WebSocket, ports: list):
        if websocket in self.active_connections:
            self.active_connections[websocket] = set(int(p) for p in ports)
            logger.info(f"WS-CLIENT  | Abo aktualisiert: {list(self.active_connections[websocket])}")

    async def broadcast_to_subscribers(self, port: int, payload: dict):
        for websocket, subscribed_ports in self.active_connections.items():
            if port in subscribed_ports:
                try:
                    await websocket.send_json(payload)
                except Exception:
                    pass

manager = ConnectionManager()

async def stream_temperatures_to_websocket(websocket, bungalow, start, end):
    """
    Holt Daten aus der SP und pumpt sie als JSON-konforme Chunks zum Client.
    Nutzt Duck-Typing, um Import-Konflikte (datetime/timedelta) zu umgehen.
    """
    db_cfg = app.state.db_temp 
    conn = None
    try:
        conn = await aiomysql.connect(
            host=db_cfg['db_host'], 
            user=db_cfg['db_user'],
            password=db_cfg['db_pwd'], 
            db=db_cfg['db_name']
        )
        
        async with conn.cursor(aiomysql.DictCursor) as cur:
            logging.info(f"DB-FETCH   | SP-Aufruf für {bungalow}: {start} bis {end}")
            
            # Aufruf der Stored Procedure
            await cur.callproc('Bungalow.proc_Temperatur_Master_1', (bungalow, start, end))
            all_results = await cur.fetchall()
            
            total = len(all_results)
            sent = 0
            logging.info(f"DB-STREAM  | {total} Sätze gefunden. Starte Versand...")

            while sent < total:
                # Dynamische Chunk-Größe: Erst 1000, dann 5000
                current_size = 1000 if sent < 3000 else 5000
                batch = all_results[sent : sent + current_size]
                
                json_ready_chunk = []
                for row in batch:
                    clean_row = {}
                    for key, value in row.items():
                        # 1. Fall: Datum/Uhrzeit (hat isoformat-Methode)
                        if hasattr(value, 'isoformat'):
                            clean_row[key] = value.isoformat()
                        
                        # 2. Fall: Zeitspannen/Timedelta (hat total_seconds-Methode)
                        elif hasattr(value, 'total_seconds'):
                            clean_row[key] = str(value)
                        
                        # 3. Fall: MySQL Decimal (Zahlen mit Komma)
                        elif isinstance(value, Decimal):
                            clean_row[key] = float(value)
                        
                        # 4. Fall: Alles andere (Strings, Ints, Floats)
                        else:
                            clean_row[key] = value
                    
                    json_ready_chunk.append(clean_row)

                # Paket über den WebSocket senden
                await websocket.send_json({
                    "action": "temp_data_chunk",
                    "data": json_ready_chunk,
                    "progress": round((sent + len(batch)) / total * 100, 1)
                })
                
                sent += len(batch)
                # Kurze Pause, damit der Server auch andere Anfragen bearbeiten kann
                await asyncio.sleep(0.01)

            # Abschluss-Signal für das Frontend (Spinner stoppen)
            await websocket.send_json({"action": "temp_stream_finished"})
            logging.info("DB-STREAM  | Übertragung erfolgreich beendet.")

    except Exception as e:
        logging.error(f"STREAM-ERR | Fehler beim Streaming: {e}")
        try:
            await websocket.send_json({"action": "temp_stream_finished"})
        except:
            pass
    finally:
        if conn:
            conn.close()

# --- UDP LISTENER ---
class SmartHomeUDP(asyncio.DatagramProtocol):
    def __init__(self, port):
        self.port = port

    def datagram_received(self, data, addr):
        try:
            raw_msg = data.decode("utf-8", "ignore").strip()
            now = datetime.now()
            sender_ip, sender_port = addr
            logging.info(f"UDP-IN [Port {self.port}] von {sender_ip}: {raw_msg}")

            log_match = re.search(r'\[(INFO|WARN|ERROR|DEBUG)\]', raw_msg)
            if log_match:
                msg_type, log_level = "log", log_match.group(1)
                clean_msg = raw_msg.split(']:', 1)[-1].strip() if ']:' in raw_msg else raw_msg
            else:
                msg_type, log_level = "pulse", None
                clean_msg = raw_msg

            payload = {
                "type": msg_type,
                "received_on_port": int(self.port),
                "timestamp": now.strftime("%d.%m.%Y %H:%M:%S"),
                "time": now.strftime("%H:%M:%S"),
                "sender_ip": sender_ip,
                "sender_port": sender_port,
                "message": clean_msg,
                "level": log_level
            }
            asyncio.create_task(manager.broadcast_to_subscribers(int(self.port), payload))
        except Exception as e:
            logging.error(f"UDP-PARSER-FEHLER | {e}")

# --- WEBSOCKET ENDPUNKT ---
@app.websocket("/ws")
@app.websocket("/")
async def websocket_endpoint(websocket: WebSocket):
    await manager.connect(websocket)
    schalten_script = "/home/pi/Schalten"
    
    try:
        while True:
            data = await websocket.receive_json()
            action = data.get("action")
            
            if action == "request_all_doses":
                try:
                    process = await asyncio.create_subprocess_exec(
                        schalten_script, "-a",
                        stdout=asyncio.subprocess.PIPE,
                        stderr=asyncio.subprocess.PIPE
                    )
                    stdout, _ = await process.communicate()
                    if process.returncode == 0 and stdout:
                        all_doses = json.loads(stdout.decode())
                        await websocket.send_json({"action": "getData-response", "data": all_doses})
                except Exception as e:
                    logging.error(f"INIT-ERROR | {e}")

            elif action == "Schalten":
                bezeichnung = data.get("bezeichnung")
                status = "1" if str(data.get("status")) == "1" else "0"
                try:
                    process = await asyncio.create_subprocess_exec(
                        schalten_script, bezeichnung, status, "-a",
                        stdout=asyncio.subprocess.PIPE,
                        stderr=asyncio.subprocess.PIPE
                    )
                    stdout, stderr = await process.communicate()
                    if process.returncode == 0 and stdout:
                        updated_info = json.loads(stdout.decode())
                        if isinstance(updated_info, list) and len(updated_info) > 0:
                            await websocket.send_json(updated_info[0])
                except Exception as e:
                    logging.error(f"PROC-ERROR | {e}")

            elif action == "subscribe":
                ports = [int(p) for p in data.get("ports", []) if str(p).isdigit()]
                await manager.update_subscription(websocket, ports)

            elif action == "unsubscribe":
                await manager.update_subscription(websocket, [])
                # Oder falls Methode oben ergänzt: await manager.unsubscribe(websocket)

            elif action == "request_temp_history":
                bungalow = data.get("bungalow", "B5")
                start = data.get("start")
                end = data.get("end")
                asyncio.create_task(stream_temperatures_to_websocket(websocket, bungalow, start, end))

    except WebSocketDisconnect:
        manager.disconnect(websocket)
    except Exception as e:
        logging.error(f"WS-GLOBAL-ERROR | {e}")
        manager.disconnect(websocket)

# --- STARTUP ---
async def main():
    parser = argparse.ArgumentParser(description="FastAPI SmartHome Server")
    parser.add_argument('--udp-ip', type=str, default='0.0.0.0')
    parser.add_argument('--websocket-ip', type=str, default='0.0.0.0')
    parser.add_argument('-u', '--udp-ports', type=str, nargs='+', default=["5005", "5006", "5007"])
    parser.add_argument('-w', '--websocket-port', type=int, default=None)
    parser.add_argument('-q', '--quiet', action='store_true')

    args = parser.parse_args()
    if args.quiet:
        logging.getLogger().setLevel(logging.WARNING)

    credentials_path = '/home/pi/.credentials.toml'
    try:
        config = toml.load(credentials_path)
        app.state.db_temp = config.get('temperatur')
        app.state.db_zaehler = config.get('zaehlen')
        logging.info(f"CONFIG-LOAD | {credentials_path} erfolgreich geladen.")
    except Exception as e:
        logging.critical(f"CONFIG-ERROR| {e}")
        return

    udp_ports_to_listen = [int(p) for p in args.udp_ports]
    loop = asyncio.get_running_loop()

    for p in udp_ports_to_listen:
        await loop.create_datagram_endpoint(
            lambda p=p: SmartHomeUDP(p), 
            local_addr=(args.udp_ip, p)
        )
        logging.info(f"UDP-READY   | Port {p} aktiv.")

    if args.websocket_port is not None:
        config_uv = Config(app=app, host=args.websocket_ip, port=args.websocket_port, log_level="info")
        server = Server(config_uv)
        await server.serve()

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        pass