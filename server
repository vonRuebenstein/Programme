# --- DYNAMISCHER MULTI-DB HANDLER ---
class MultiDatabaseHandler:
    def __init__(self):
        self.session_makers: Dict[str, async_sessionmaker] = {}
        self.engines = {}

    async def init_all_sections(self, full_config: dict):
        """
        Iteriert durch alle Sektionen der TOML und baut 
        individuelle Verbindungen auf.
        """
        required = ['db_host', 'db_user', 'db_pwd', 'db_name']
        for section, cfg in full_config.items():
            # Validierung: Hat die Sektion alle nötigen Login-Daten?
            if isinstance(cfg, dict) and all(k in cfg for k in required):
                try:
                    # Hier werden User, Passwort, Host und DB individuell pro Sektion gesetzt
                    db_url = f"mysql+aiomysql://{cfg['db_user']}:{cfg['db_pwd']}@{cfg['db_host']}/{cfg['db_name']}"
                    
                    engine = create_async_engine(
                        db_url, 
                        pool_pre_ping=True, 
                        pool_size=5, 
                        max_overflow=10
                    )
                    
                    self.engines[section] = engine
                    self.session_makers[section] = async_sessionmaker(engine, expire_on_commit=False)
                    logger.info(f"DB-CONFIG  | Sektion '{section}' erfolgreich mit User '{cfg['db_user']}' verbunden.")
                except Exception as e:
                    logger.error(f"DB-ERROR   | Konnte Sektion '{section}' nicht initialisieren: {e}")

    def get_session(self, section: str) -> async_sessionmaker:
        if section not in self.session_makers:
            raise ValueError(f"Datenbank-Sektion '{section}' ist unbekannt oder nicht konfiguriert!")
        return self.session_makers[section]

    async def close_all(self):
        for section, engine in self.engines.items():
            await engine.dispose()
            logger.info(f"DB-SHUTDOWN| Verbindung zu '{section}' getrennt.")

db_handler = MultiDatabaseHandler()

# --- LIFESPAN ---
@asynccontextmanager
async def lifespan(app: FastAPI):
    # Alle Sektionen aus der Config beim Start laden
    await db_handler.init_all_sections(app.state.full_config)
    yield
    # Beim Beenden alle Verbindungen schließen
    await db_handler.close_all()

app = FastAPI(lifespan=lifespan)

