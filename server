)

# --- CONNECTION MANAGER (Abo-System) ---
class ConnectionManager:
    def __init__(self):
        self.active_connections: dict[WebSocket, Set[int]] = {}

    async def connect(self, websocket: WebSocket):
        await websocket.accept()
        self.active_connections[websocket] = set()
        logger.info(f"WS-CLIENT  | Verbunden. Gesamt: {len(self.active_connections)}")

    def disconnect(self, websocket: WebSocket):
        if websocket in self.active_connections:
            del self.active_connections[websocket]
            logger.info(f"WS-CLIENT  | Getrennt. Rest: {len(self.active_connections)}")

    async def subscribe(self, websocket: WebSocket, ports: list):
        if websocket in self.active_connections:
            # Fügt neue Ports hinzu, entfernt keine alten (erweitert das Abo)
            new_ports = {int(p) for p in ports if str(p).isdigit()}
            self.active_connections[websocket].update(new_ports)
            logger.info(f"WS-CLIENT  | Abo erweitert: {list(self.active_connections[websocket])}")

    async def unsubscribe(self, websocket: WebSocket, ports: list):
        if websocket in self.active_connections:
            # Entfernt gezielt nur die genannten Ports
            for p in ports:
                try: self.active_connections[websocket].remove(int(p))
                except: continue
            logger.info(f"WS-CLIENT  | Abo reduziert. Rest: {list(self.active_connections[websocket])}")

    async def broadcast_to_subscribers(self, port: int, payload: dict):
        for websocket, subs in self.active_connections.items():
            if port in subs:
                try: await websocket.send_json(payload)
                except: pass

manager = ConnectionManager()

# --- BUSINESS LOGIC: TEMPERATURE STREAMING ---
async def stream_temperatures_to_websocket(websocket, bungalow, start, end):
    try:
        make_session = db_handler.get_session("temperatur")
        
        async with make_session() as session:
            query = text("CALL Bungalow.proc_Temperatur_Master_1(:b, :s, :e)")
            result = await session.execute(query, {"b": bungalow, "s": start, "e": end})
            
            # 1. Alle Ergebnisse holen
            all_rows = result.mappings().all()
            
            # 2. EXPLIZITE SORTIERUNG (Der Sicherheitsanker)
            # Wir sortieren nach dem Feld 'Zeitpunkt', damit Plotly keine Zick-Zack-Linien zieht
            sorted_data = sorted(all_rows, key=lambda x: x['Zeitpunkt'])
            
            total = len(sorted_data)
            sent = 0
            logger.info(f"DB-STREAM  | Sende {total} Datensätze für {bungalow}")

            # 3. Chunking auf den sortierten Daten
            chunk_size = 5000
            for i in range(0, total, chunk_size):
                batch = sorted_data[i : i + chunk_size]
                
                # Konvertierung ins JS-Format via Pydantic
                json_batch = [TempData(**row).model_dump(mode='json', by_alias=True) for row in batch]
                
                await websocket.send_json({
                    "action": "temp_data_chunk", 
                    "data": json_batch,
                    "progress": round((sent + len(batch)) / total * 100, 1)
                })
                sent += len(batch)
                await asyncio.sleep(0.01) # Kurze Pause für die Event-Loop

            await websocket.send_json({"action": "temp_stream_finished"})
            
    except Exception as e:
        logger.error(f"STREAM-ERR | {e}")
        try: await websocket.send_json({"action": "temp_stream_finished"})
        except: pass

# --- UDP SENSOR LISTENER ---
class SmartHomeUDP(asyncio.DatagramProtocol):
    def __init__(self, port):
        self.port = port

    def datagram_received(self, data, addr):
        try:
            raw_msg = data.decode("utf-8", "ignore").strip()
            sender_ip, sender_port = addr
            now = datetime.now()
            logger.info(f"UDP-IN [Port {self.port}] von {sender_ip}: {raw_msg}")
            
            # Original RegEx Search
            log_match = re.search(r'\[(INFO|WARN|ERROR|DEBUG)\]', raw_msg)
            
            # Original Message Parsing Logik
            if log_match:
                msg_type, log_level = "log", log_match.group(1)
                clean_msg = raw_msg.split(']:', 1)[-1].strip() if ']:' in raw_msg else raw_msg
            else:
                msg_type, log_level = "pulse", None
                clean_msg = raw_msg

            payload = {
                "type": msg_type,
                "received_on_port": int(self.port),
                "timestamp": now.strftime("%d.%m.%Y %H:%M:%S"),
                "time": now.strftime("%H:%M:%S"),
                "sender_ip": sender_ip,
                "sender_port": sender_port,
                "message": clean_msg,
                "level": log_level
            }
            asyncio.create_task(manager.broadcast_to_subscribers(int(self.port), payload))
        except Exception as e:
            logger.error(f"UDP-ERR    | {e}")

# --- WEBSOCKET ENDPOINT & ROUTING ---
@app.websocket("/ws")
@app.websocket("/")
async def websocket_endpoint(websocket: WebSocket):
    await manager.connect(websocket)
    schalten_script = "/home/pi/Schalten" # Original Pfad
    
    try:
        while True:
            data = await websocket.receive_json()
            action = data.get("action")
            
            # Original Actions
            if action == "request_all_doses":
                try:
                    process = await asyncio.create_subprocess_exec(
                        schalten_script, "-a",
                        stdout=asyncio.subprocess.PIPE,
                        stderr=asyncio.subprocess.PIPE
                    )
                    stdout, _ = await process.communicate()
                    if process.returncode == 0 and stdout:
                        await websocket.send_json({"action": "getData-response", "data": json.loads(stdout.decode())})
                except Exception as e: logger.error(f"INIT-ERROR | {e}")

            elif action == "Schalten":
                bezeichnung = data.get("bezeichnung")
                status_val = "1" if str(data.get("status")) == "1" else "0"
                try:
                    process = await asyncio.create_subprocess_exec(
                        schalten_script, bezeichnung, status_val, "-a",
                        stdout=asyncio.subprocess.PIPE,
                        stderr=asyncio.subprocess.PIPE
                    )
                    stdout, _ = await process.communicate()
                    if process.returncode == 0 and stdout:
                        updated = json.loads(stdout.decode())
                        if isinstance(updated, list) and updated:
                            await websocket.send_json(updated[0])
                except Exception as e: logger.error(f"PROC-ERROR | {e}")

            elif action == "subscribe":
                await manager.subscribe(websocket, data.get("ports", []))

            elif action == "unsubscribe":
                await manager.unsubscribe(websocket, data.get("ports", []))

            elif action == "request_temp_history":
                asyncio.create_task(stream_temperatures_to_websocket(
                    websocket, 
                    data.get("bungalow", "B5"), # Original Default
                    data.get("start"), 
                    data.get("end")
                ))

    except WebSocketDisconnect:
        manager.disconnect(websocket)
    except Exception as e:
        logger.error(f"WS-GLOBAL-ERROR | {e}")
        manager.disconnect(websocket)

# --- MAIN & STARTUP SEQUENCE ---
async def main():
    # --- ORIGINALER PARSER ---
    parser = argparse.ArgumentParser(description="FastAPI SmartHome Server")
    parser.add_argument('--udp-ip', type=str, default='0.0.0.0')
    parser.add_argument('--websocket-ip', type=str, default='0.0.0.0')
    parser.add_argument('-u', '--udp-ports', type=str, nargs='+', default=["5005", "5006", "5007"])
    parser.add_argument('-w', '--websocket-port', type=int, default=None)
    parser.add_argument('-q', '--quiet', action='store_true')

    args = parser.parse_args()

    # Logik für Quiet-Mode
    if args.quiet:
        logging.getLogger().setLevel(logging.WARNING)

    # Config laden (Gesamte TOML für Multi-DB)
    try:
        app.state.full_config = toml.load('/home/pi/.credentials.toml')
    except Exception as e:
        logger.critical(f"CONFIG-ERROR| {e}"); return

    # UDP-Server mit korrekter IP aus Args starten
    loop = asyncio.get_running_loop()
    for p in [int(port) for port in args.udp_ports]:
        await loop.create_datagram_endpoint(
            lambda p=p: SmartHomeUDP(p), 
            local_addr=(args.udp_ip, p)
        )
        logger.info(f"UDP-READY   | Port {p} aktiv auf {args.udp_ip}")

    # WebSocket-Server nur starten, wenn Port definiert (Original-Logik)
    if args.websocket_port is not None:
        config_uv = Config(
            app=app, 
            host=args.websocket_ip, 
            port=args.websocket_port, 
            log_level="info"
        )
        server = Server(config_uv)
        await server.serve()

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt: pass