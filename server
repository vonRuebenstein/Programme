#!/usr/bin/env python3
import asyncio
import logging
import json
import argparse
import toml
import aiomysql
import re
from datetime import datetime, date
from decimal import Decimal
from fastapi import FastAPI, WebSocket, WebSocketDisconnect
from fastapi.middleware.cors import CORSMiddleware
from uvicorn import Config, Server
from fastapi.middleware.trustedhost import TrustedHostMiddleware

# --- LOGGING ---
logging.basicConfig(level=logging.INFO, format='%(asctime)s | %(levelname)-7s | %(message)s', datefmt='%H:%M:%S')
logger = logging.getLogger("SmartServer")

app = FastAPI()
app.add_middleware(TrustedHostMiddleware, allowed_hosts=["*"])

# --- CORS (Sicherheits-Erlaubnis für Browser) ---
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# --- CONNECTION MANAGER (Abo-Modell) ---
class ConnectionManager:
    def __init__(self):
        # Speichert {WebSocket: set([port1, port2])}
        self.active_connections: dict[WebSocket, set] = {}

    async def connect(self, websocket: WebSocket):
        await websocket.accept()
        self.active_connections[websocket] = set()
        logger.info(f"WS-CLIENT  | Verbunden. Gesamt: {len(self.active_connections)}")

    def disconnect(self, websocket: WebSocket):
        if websocket in self.active_connections:
            del self.active_connections[websocket]
            logger.info(f"WS-CLIENT  | Getrennt. Rest: {len(self.active_connections)}")

    async def update_subscription(self, websocket: WebSocket, ports: list):
        if websocket in self.active_connections:
            # Ports in Integer wandeln zur Sicherheit
            self.active_connections[websocket] = set(int(p) for p in ports)
            logger.info(f"WS-CLIENT  | Abo aktualisiert: {list(self.active_connections[websocket])}")

    async def broadcast_to_subscribers(self, port: int, payload: dict):
        for websocket, subscribed_ports in self.active_connections.items():
            if port in subscribed_ports:
                try:
                    await websocket.send_json(payload)
                except Exception:
                    pass

manager = ConnectionManager()

# --- UNIVERSAL DB STREAMER (Für Temperatur & Zähler) ---
async def stream_from_db(websocket, bungalow, start, end, db_cfg, procedure, action_label):
    logger.info(f"DB-STREAM  | {action_label} für {bungalow} via {procedure}")
    try:
        conn = await aiomysql.connect(
            host=db_cfg['db_host'], user=db_cfg['db_user'],
            password=db_cfg['db_pwd'], db=db_cfg['db_name']
        )
        async with conn.cursor(aiomysql.DictCursor) as cur:
            await cur.callproc(procedure, (bungalow, start, end, 0, 100000))
            rows = await cur.fetchall()
            
            chunk_size = 2000
            for i in range(0, len(rows), chunk_size):
                chunk = rows[i:i + chunk_size]
                for row in chunk:
                    for k, v in row.items():
                        if isinstance(v, (datetime, date)): row[k] = v.isoformat()
                        elif isinstance(v, Decimal): row[k] = float(v)
                
                await websocket.send_json({
                    "action": f"{action_label}_chunk",
                    "data": chunk,
                    "last": (i + chunk_size >= len(rows))
                })
        conn.close()
        logger.info(f"DB-STREAM  | {action_label} fertig.")
    except Exception as e:
        logger.error(f"DB-FEHLER  | {e}")

# --- UDP LISTENER (Input von Loggern) ---
class SmartHomeUDP(asyncio.DatagramProtocol):
    def __init__(self, port):
        self.port = port

    def datagram_received(self, data, addr):
        try:
            raw_msg = data.decode("utf-8", "ignore").strip()
            now = datetime.now()
            sender_ip, sender_port = addr
            
            # --- NEU: Konsolen-Ausgabe ---
            # So siehst du sofort, was auf welchem Port reinkommt
            logging.info(f"UDP-IN [Port {self.port}] von {sender_ip}: {raw_msg}")

            # Log-Eintrag erkennen
            log_match = re.search(r'\[(INFO|WARN|ERROR|DEBUG)\]', raw_msg)
            if log_match:
                msg_type, log_level = "log", log_match.group(1)
                clean_msg = raw_msg.split(']:', 1)[-1].strip() if ']:' in raw_msg else raw_msg
            else:
                msg_type, log_level = "pulse", None
                clean_msg = raw_msg

            # Payload für das Frontend
            payload = {
                "type": msg_type,
                "received_on_port": int(self.port),
                "timestamp": now.strftime("%d.%m.%Y %H:%M:%S"),
                "time": now.strftime("%H:%M:%S"),
                "sender_ip": sender_ip,
                "sender_port": sender_port,
                "message": clean_msg,
                "level": log_level
            }
            
            # Weiterleiten an WebSocket-Abonnenten
            asyncio.create_task(manager.broadcast_to_subscribers(int(self.port), payload))
            
        except Exception as e:
            logging.error(f"UDP-PARSER-FEHLER | {e}")

# --- WEBSOCKET ENDPUNKT ---
@app.websocket("/ws")
@app.websocket("/")
async def websocket_endpoint(websocket: WebSocket):
    await manager.connect(websocket)
    try:
        while True:
            data = await websocket.receive_json()
            action = data.get("action")
            
            if action == "subscribe":
                await manager.update_subscription(websocket, data.get("ports", []))
            
            elif action == "get_history": # Temperatur
                await stream_from_db(websocket, data['bungalow'], data['start'], data['end'], 
                                   app.state.db_temp, 'Bungalow.proc_Temperatur_Master', 'temp')
            
            elif action == "get_zaehler": # Zähler
                await stream_from_db(websocket, data['bungalow'], data['start'], data['end'], 
                                   app.state.db_zaehler, 'Bungalow.proc_Zaehler_Master', 'zaehler')
            
            elif action == "unsubscribe":
                await manager.update_subscription(websocket, [])

    except WebSocketDisconnect:
        manager.disconnect(websocket)
    except Exception as e:
        logger.error(f"WS-LOOP-FEHLER | {e}")
        manager.disconnect(websocket)

# --- STARTUP ---
async def main():
    """Hauptfunktion des Servers, die Argumente parst und Listener startet."""
    
    parser = argparse.ArgumentParser(
        description="FastAPI SmartHome Server - Asynchrone Version",
        formatter_class=argparse.RawTextHelpFormatter
    )
    
    # --- 1:1 Übernahme deiner alten Argumente ---
    parser.add_argument(
        '--udp-ip',
        type=str, # Hier kannst du deine ip_address_type Funktion einsetzen
        default='0.0.0.0',
        help="IP-Adresse oder Hostname für den UDP-Listener."
    )
    parser.add_argument(
        '--websocket-ip',
        type=str,
        default='0.0.0.0',
        help="IP-Adresse oder Hostname für den WebSocket-Server."
    )
    parser.add_argument(
        '-u', '--udp-ports',
        type=str,
        nargs='+',
        default=["5005", "5006", "5007"],
        help="Liste von UDP-Ports."
    )
    parser.add_argument(
        '-w', '--websocket-port',
        type=int, # Entspricht deinem port_type
        default=None,
        help="Port für den WebSocket-Server. Falls None, startet kein WS."
    )
    parser.add_argument(
        '-q', '--quiet',
        action='store_true',
        help="Schaltet INFO-Meldungen ab."
    )

    args = parser.parse_args()

    # --- Loglevel wie gewohnt ---
    if args.quiet:
        logging.getLogger().setLevel(logging.WARNING)
    
    # Ports konvertieren (wie dein alter port_list_type)
    udp_ports_to_listen = [int(p) for p in args.udp_ports]

    # --- Datenbank-Konfiguration laden ---
    config = toml.load('/home/pi/.credentials.toml')
    app.state.db_temp = config['temperatur']
    app.state.db_zaehler = config.get('zaehler')

    loop = asyncio.get_running_loop()

    # --- UDP Listener starten ---
    for p in udp_ports_to_listen:
        # Hier nutzen wir args.udp_ip
        await loop.create_datagram_endpoint(
            lambda p=p: SmartHomeUDP(p), 
            local_addr=(args.udp_ip, p)
        )
        logging.info(f"UDP-READY  | Port {p} aktiv auf {args.udp_ip}")

    # --- WebSocket Server starten (nur wenn -w angegeben wurde) ---
    if args.websocket_port is not None:
        logging.info(f"WS-READY   | Starte FastAPI/Uvicorn auf {args.websocket_ip}:{args.websocket_port}")
        
        # Uvicorn Konfiguration nutzt explizit die websocket-ip
        config = Config(
            app=app, 
            host=args.websocket_ip, 
            port=args.websocket_port, 
            log_level="warning" if args.quiet else "info"
        )
        server = Server(config)
        await server.serve()
    else:
        logging.warning("WS-SKIP    | Kein WebSocket-Port angegeben (-w). Server läuft nur als UDP-Logger.")
        # Wenn kein WS läuft, müssen wir den Loop am Leben erhalten
        while True:
            await asyncio.sleep(3600)

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        logger.info("SYSTEM     | Server manuell gestoppt.")