def Ausgabe(Ziel, Sensor, CRC, Temp, Bezeichnung, db, SensorID):
    CSVSeperator = ";"
    CSVListe = [time.strftime("%d.%m.%Y"), time.strftime("%H:%M"), Sensor, CRC, str(Temp).replace(".", ","), Bezeichnung]

    if Ziel == "":
        for x in CSVListe:
            print(x, end=" ")
        print()
    elif Ziel == "db":
        try:
            # Jetzt verwenden wir den DatabaseManager
            db.execute_query("INSERT INTO Bungalow.Tempwerte(Datum, Zeit, Temperatur, CRC, TempSensor_ID) VALUES (%s, %s, %s, %s, %s)",
                             (time.strftime("%Y-%m-%d"), time.strftime("%H:%M:00"), Temp, CRC, SensorID), fetch_results=False)
        except Exception as e:
            logging.error(f"Fehler beim Einfügen in die Datenbank: {e}")
    else:
        try:
            CSVOut = csv.writer(open(Ziel, "a"), delimiter=CSVSeperator)
            CSVOut.writerow(CSVListe)
        except FileNotFoundError as err:
            print(time.strftime("%d.%m.%Y %H:%M:%S"), "CSV Datei oder Pfad nicht gefunden", file=sys.stderr)
        except PermissionError as err:
            print(time.strftime("%d.%m.%Y %H:%M:%S"), "Keine Berechtigung für Pfad", Ziel, file=sys.stderr)
    return()

def Schalten(Temp, Dose):
    Programm = '/home/pi/Schalten'
    SchaltenUeberhaupt = 7
    Heizung_Ein = 3
    Heizung_Aus = 5

    if Temp < SchaltenUeberhaupt and Dose is not None:
        sliste = [Programm, Dose]
        if Temp <= Heizung_Ein:
            sliste.append('1')
        elif Temp >= Heizung_Aus:
            sliste.append('0')
        
        try:
            s = subprocess.Popen(sliste)
        except FileNotFoundError:
            print(time.strftime("%d.%m.%Y %H:%M:%S"), f"Programm {sliste[0]} nicht gefunden", file=sys.stderr)
        else:
            s.wait()
    return()

