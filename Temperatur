class DatabaseManager:
    """
    Verwaltet die Datenbankverbindung und -operationen robuster.
    Implementiert Wiederverbindungsversuche und Kontext-Manager-Protokoll.
    """
    RETRY_ATTEMPTS = 5      # Maximale Anzahl der Wiederholungsversuche bei Verbindungsfehlern
    RETRY_DELAY_BASE = 2    # Basis-Verzögerung in Sekunden für Exponential Backoff

    def __init__(self, db_host, db_name, db_user, db_pwd):
        self.__db_host = db_host
        self.__db_name = db_name
        self.__db_user = db_user
        self.__db_pwd = db_pwd
        self.__connection = None
        self.__is_connected = False
        self._connect()

    def _connect(self):
        """
        Versucht, eine Verbindung zur MySQL-Datenbank aufzubauen.
        Implementiert Exponential Backoff für Wiederholungsversuche.
        """
        for attempt in range(self.RETRY_ATTEMPTS):
            try:
                self.__connection = mysql.connector.connect(
                    host=self.__db_host,
                    database=self.__db_name,
                    user=self.__db_user,
                    password=self.__db_pwd,
                    autocommit=False # Manuelles Transaktionsmanagement
                )
                if self.__connection.is_connected():
                    logging.info("Erfolgreich mit der Datenbank verbunden.")
                    self.__is_connected = True
                    return True
            except mysql.connector.Error as err:
                logging.warning(f"Verbindungsversuch {attempt + 1}/{self.RETRY_ATTEMPTS} zur Datenbank {self.__db_host}/{self.__db_name} fehlgeschlagen: {err}")
                if attempt < self.RETRY_ATTEMPTS - 1:
                    # Exponential Backoff
                    delay = self.RETRY_DELAY_BASE * (2 ** attempt)
                    logging.info(f"Warte {delay} Sekunden vor dem nächsten Verbindungsversuch...")
                    time.sleep(delay)
                else:
                    logging.critical(f"Alle {self.RETRY_ATTEMPTS} Verbindungsversuche fehlgeschlagen. Programm wird beendet.")
                    sys.exit(1) # Beende das Programm, wenn keine Verbindung möglich ist
        self.__is_connected = False
        return False

    def is_connected(self):
        """Überprüft, ob die Datenbankverbindung aktiv ist."""
        return self.__is_connected and self.__connection and self.__connection.is_connected()

    def execute_query(self, query: str, params=None, fetch_results=True):
        """
        Führt eine SQL-Abfrage aus und gibt die Ergebnisse zurück (falls zutreffend).
        Umfasst Fehlerbehandlung und Transaktionsmanagement.
        """
        if not self.is_connected():
            logging.info("Datenbankverbindung nicht aktiv oder verloren. Versuche Neuverbindung...")
            if not self._connect(): # Versuche, die Verbindung wiederherzustellen
                return None # Neuverbindung fehlgeschlagen

        cursor = None
        try:
            cursor = self.__connection.cursor()
            cursor.execute(query, params)

            if query.strip().upper().startswith("SELECT") and fetch_results:
                columns = [col[0] for col in cursor.description]
                results = cursor.fetchall()
                # Rückgabe einer Liste von Dictionaries statt einer Liste von Tupeln
                data = [dict(zip(columns, row)) for row in results]
                return data
            else:
                self.__connection.commit() # Änderungen festschreiben
                return True
        except mysql.connector.Error as err:
            logging.error(f"Datenbankfehler bei Ausführung von Query: '{query}' - {err}")
            if self.__connection:
                self.__connection.rollback() # Änderungen rückgängig machen bei Fehler
            return False
        except Exception as e:
            logging.error(f"Ein unerwarteter Fehler ist aufgetreten: {e}", exc_info=True)
            if self.__connection:
                self.__connection.rollback()
            return False
        finally:
            if cursor:
                cursor.close()

    def close(self):
        """Schließt die Datenbankverbindung, falls sie aktiv ist."""
        if self.__connection and self.__connection.is_connected():
            self.__connection.close()
            self.__is_connected = False
            logging.info("Datenbankverbindung geschlossen.")

    def __enter__(self):
        """Einstiegspunkt für den Kontext-Manager."""
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """Ausstiegspunkt für den Kontext-Manager, schließt die Verbindung."""
        self.close()

def load_config_from_toml(file_path: str, sektion: str, required_keys: list) -> dict:
    """Lädt Konfigurationsdaten aus einer TOML-Datei."""
    if not os.path.exists(file_path):
        raise FileNotFoundError(f"Konfigurationsdatei nicht gefunden: {file_path}")

    try:
        with open(file_path, 'r') as f:
            data = toml.load(f)
            if not isinstance(data, dict):
                raise ValueError(f"Ungültige Konfiguration: {file_path} enthält kein Wörterbuch.")

            if sektion not in data:
                raise ValueError(f"Fehlende '{sektion}'-Sektion in {file_path}.")

            config_data = data[sektion]

            for key in required_keys:
                if key not in config_data:
                    if key == "mqtt_get_topic_suffix":
                        config_data[key] = None
                    else:
                        raise ValueError(f"Fehlender erforderlicher Schlüssel '{key}' in der '{sektion}'-Sektion von {file_path}.")

            log_level_str = config_data.get("log_level", "INFO").upper()
            config_data["log_level_value"] = getattr(logging, log_level_str, logging.INFO)

            return config_data
    except toml.TomlDecodeError as e:
        raise ValueError(f"Fehler beim Decodieren von TOML aus {file_path}: {e}")
    except Exception as e:
        raise RuntimeError(f"Unerwarteter Fehler beim Lesen von {file_path}: {e}")

