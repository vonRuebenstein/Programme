# --- Formatierungs- und Input-Funktionen (unverändert) ---
def FormatAusgabe (Datei,Zeit,Stand,Zeitdiff,Entnahme,Einheit):
    Ausgabe=f"{time.strftime('%d.%m.%Y %H:%M:%S', time.localtime(int(Zeit)))} {Datei} {Stand:09.3f}   {Zeitdiff:11.2f}s {Entnahme:8.2f}"
    Ausgabe=Ausgabe+Einheit
    return(Ausgabe)

def InputNumeric(Prompt,Stringerlaubt):
    while True:
        i=input(Prompt)
        if i==Stringerlaubt:
            break
        try:
            i=float(i)
        except ValueError as err:
            continue
        else:
            i=abs(i)
            break
    return(i)

