# --- Funktion zum Laden der Konfigurationsdatei (angepasst für TOML) ---
def load_config_from_toml(file_path: str) -> dict:
    """Lädt Konfigurationsdaten aus einer TOML-Datei."""
    if not os.path.exists(file_path):
        raise FileNotFoundError(f"Konfigurationsdatei nicht gefunden: {file_path}")
    
    try:
        with open(file_path, 'r') as f:
            data = toml.load(f)
            if not isinstance(data, dict):
                raise ValueError(f"Ungültige Konfiguration: {file_path} enthält kein Wörterbuch.")
            
            # Prüfen, ob die 'zaehlen'-Sektion und alle benötigten Schlüssel vorhanden sind
            # Die Schlüssel sind hier 'db_host', 'db_user', 'db_pwd', 'db_name' wie in der .toml definiert
            required_keys = ["db_host", "db_user", "db_pwd", "db_name"]
            if "zaehlen" not in data or not all(key in data["zaehlen"] for key in required_keys):
                raise ValueError(f"Fehlende erforderliche Schlüssel in der 'zaehlen'-Sektion von {file_path}.")
            
            return data["zaehlen"]
    except toml.TomlDecodeError as e:
        raise ValueError(f"Fehler beim Decodieren von TOML aus {file_path}: {e}")
    except Exception as e:
        raise RuntimeError(f"Unerwarteter Fehler beim Lesen von {file_path}: {e}")

# --- Laden der Anmeldeinformationen beim Start des Skripts ---
